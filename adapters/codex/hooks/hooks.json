{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "${PLUGIN_ROOT}/hooks/scripts/protected-paths.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "${PLUGIN_ROOT}/hooks/scripts/graph-update.sh" },
          { "type": "command", "command": "${PLUGIN_ROOT}/hooks/scripts/lint-on-edit.sh" }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          { "type": "command", "command": "${PLUGIN_ROOT}/hooks/scripts/reviewer-route-gate.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "${PLUGIN_ROOT}/hooks/scripts/stop-gate.sh" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "${PLUGIN_ROOT}/hooks/scripts/stop-gate.sh" }
        ]
      }
    ]
  }
}
